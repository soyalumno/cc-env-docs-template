---
import Icon from './Icon.astro';
---

<button id="search-trigger" class="search-trigger" aria-label="検索">
  <Icon name="scan" size="16px" />
  <span class="search-label">検索</span>
</button>

<dialog id="search-dialog" class="search-dialog">
  <div class="search-container">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-input-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="キーワードで検索..."
          class="search-input"
          autocomplete="off"
        />
      </div>
      <button id="search-close" class="search-close" aria-label="閉じる">
        <kbd>Esc</kbd>
      </button>
    </div>
    <div id="search-results" class="search-results">
      <div class="search-hint">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <p>キーワードを入力して検索</p>
        <p class="search-hint-sub">ルール・スキル・インフラのドキュメントを横断検索します</p>
      </div>
    </div>
  </div>
</dialog>

<script>
  async function initSearch() {
    const trigger = document.getElementById('search-trigger');
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement;
    const input = document.getElementById('search-input') as HTMLInputElement;
    const results = document.getElementById('search-results')!;
    const closeBtn = document.getElementById('search-close');

    let pagefind: any = null;

    const hintHtml = results.innerHTML;

    async function loadPagefind() {
      if (pagefind) return pagefind;
      const path = '/pagefind/pagefind.js';
      pagefind = await import(/* @vite-ignore */ path);
      await pagefind.init();
      return pagefind;
    }

    function openSearch() {
      dialog.showModal();
      input.focus();
      input.value = '';
      results.innerHTML = hintHtml;
    }

    function closeSearch() {
      dialog.close();
    }

    function categoryFromUrl(url: string): string {
      if (url.includes('/rules/')) return 'Rules';
      if (url.includes('/skills/')) return 'Skills';
      if (url.includes('/infra/')) return 'Infra';
      return '';
    }

    function slugFromUrl(url: string): string {
      const match = url.match(/\/(rules|skills|infra)\/([^/]+)/);
      if (!match) return '';
      const prefix = match[1] === 'skills' ? '/' : '';
      return `${prefix}${match[2]}`;
    }

    function categoryClass(cat: string): string {
      if (cat === 'Rules') return 'cat-rules';
      if (cat === 'Skills') return 'cat-skills';
      if (cat === 'Infra') return 'cat-infra';
      return '';
    }

    trigger?.addEventListener('click', openSearch);
    closeBtn?.addEventListener('click', closeSearch);
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) closeSearch();
    });


    let debounceTimer: ReturnType<typeof setTimeout>;

    input?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const query = input.value.trim();
        if (!query) {
          results.innerHTML = hintHtml;
          return;
        }

        const pf = await loadPagefind();
        const search = await pf.search(query);

        if (search.results.length === 0) {
          results.innerHTML = `
            <div class="search-no-results">
              <p>「<strong>${query}</strong>」に一致する結果はありません</p>
              <p class="search-hint-sub">別のキーワードをお試しください</p>
            </div>`;
          return;
        }

        const total = search.results.length;
        const items = await Promise.all(
          search.results.slice(0, 8).map((r: any) => r.data())
        );

        const countLabel = total > 8 ? `${total}件中 8件を表示` : `${total}件`;

        results.innerHTML = `
          <div class="search-result-count">${countLabel}</div>
          <div class="search-result-list">
            ${items.map((item: any) => {
              const cat = categoryFromUrl(item.url);
              return `
                <a href="${item.url}" class="search-result-item">
                  <div class="search-result-head">
                    ${cat ? `<span class="search-result-cat ${categoryClass(cat)}">${cat}</span>` : ''}
                    <span class="search-result-slug">${slugFromUrl(item.url)}</span>
                    <span class="search-result-title">${item.meta?.title || item.url}</span>
                  </div>
                  <div class="search-result-excerpt">${item.excerpt || ''}</div>
                </a>`;
            }).join('')}
          </div>`;
      }, 150);
    });
  }

  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>

<style is:global>
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    min-width: 200px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--bdrs--20);
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--fz--xs);
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .search-trigger:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .search-label { color: rgba(255, 255, 255, 0.6); }

  .search-kbd {
    font-family: var(--ff--mono);
    font-size: 0.6875rem;
    padding: 1px 5px;
    background: var(--base-2);
    border: 1px solid var(--divider);
    border-radius: 4px;
    color: var(--text-3);
  }

  .search-dialog {
    border: none;
    border-radius: var(--bdrs--30);
    padding: 0;
    width: min(640px, 90vw);
    max-height: min(520px, 75vh);
    box-shadow: var(--bxsh--50);
    background: var(--base);
    margin-top: 12vh;
  }

  .search-dialog::backdrop {
    background: rgba(22, 22, 26, 0.45);
    backdrop-filter: blur(4px);
  }

  .search-container {
    display: flex;
    flex-direction: column;
    max-height: min(520px, 75vh);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--divider);
    flex-shrink: 0;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    color: var(--text-3);
  }

  .search-input-icon { flex-shrink: 0; }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1.0625rem;
    font-family: var(--ff--base);
    color: var(--text);
    background: transparent;
  }

  .search-input::placeholder { color: var(--text-3); }

  .search-close {
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  .search-close kbd {
    font-family: var(--ff--mono);
    font-size: 0.6875rem;
    padding: 2px 6px;
    background: var(--base-2);
    border: 1px solid var(--divider);
    border-radius: 4px;
    color: var(--text-3);
  }

  .search-results {
    overflow-y: auto;
    flex: 1;
  }

  /* hint (initial state) */
  .search-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 48px 24px;
    color: var(--text-3);
    font-size: var(--fz--s);
  }

  .search-hint svg { opacity: 0.3; }

  .search-hint-sub {
    font-size: var(--fz--2xs);
    color: var(--text-3);
    margin: 0;
  }

  /* no results */
  .search-no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 48px 24px;
    color: var(--text-2);
    font-size: var(--fz--s);
    text-align: center;
  }

  /* result count */
  .search-result-count {
    padding: 10px 20px 6px;
    font-size: 0.6875rem;
    color: var(--text-3, #909098);
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    letter-spacing: 0.02em;
  }

  .search-result-list {
    padding: 4px 10px 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* result item — card style */
  .search-result-item {
    display: block;
    padding: 14px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text, #1c1c20);
    border: 1px solid var(--divider, #e6e6ea);
    background: var(--base-2, #f6f6f8);
    transition: background-color 0.12s, border-color 0.12s, box-shadow 0.12s;
  }

  .search-result-item:hover {
    background: var(--base, #ffffff);
    border-color: #d6d6db;
    box-shadow: 0px 2px 6px hsl(240 6% 10% / 0.08);
  }

  .search-result-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .search-result-cat {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border-radius: 4px;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .cat-rules {
    background: var(--tint-slate, #e8edf4);
    color: var(--accent, #0A3F71);
  }

  .cat-skills {
    background: var(--tint-sand, #f3efe6);
    color: #8a6d2e;
  }

  .cat-infra {
    background: var(--tint-sage, #e9efe9);
    color: #4a7a52;
  }

  .search-result-slug {
    font-size: 0.625rem;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    background: var(--base-3, #eeeef1);
    color: var(--text-2, #6e6e76);
    padding: 1px 6px;
    border-radius: 4px;
  }

  .search-result-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text, #1c1c20);
  }

  .search-result-excerpt {
    font-size: 0.8125rem;
    color: var(--text-2, #6e6e76);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-excerpt mark {
    background: #fef3c7;
    color: #1c1c20;
    padding: 1px 3px;
    border-radius: 3px;
    font-weight: 500;
  }

  .search-result-url {
    margin-top: 6px;
    font-size: 0.6875rem;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    color: #909098;
  }
</style>
