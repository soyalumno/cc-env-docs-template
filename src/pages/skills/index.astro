---
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocList from '../../components/DocList.astro';
import { Stack, Heading, Text } from 'lism-css/astro';
import { getCollection } from 'astro:content';

const skills = (await getCollection('skills')).sort((a, b) => a.data.order - b.data.order);
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Skills' },
];
---

<DocsLayout title="Skills" crumbs={crumbs}>
  <Stack g="30" w="100%">
    <Stack g="5">
      <Heading level={1} fz="2xl" fw="bold">⚡ Skills</Heading>
      <Text c="text-2" fz="s">Claude Code のカスタムスキル（トリガーワードで起動）</Text>
    </Stack>
    <DocList items={skills} basePath="/skills" category="skills" />
  </Stack>
</DocsLayout>
